# ============================================================
# .env.local.example — อบต.หัวงัว citizen-help (local dev)
# คัดลอกเป็น .env.local แล้วเติมค่าจริง (.env* ถูก .gitignore ทั้งหมดยกเว้น .example)
#
# ⚠️ ชื่อตัวแปรต้องตรง scripts/verify-env.ts (build/CI บังคับ)
#    ตัวแปรที่ verify บังคับทั้ง 10 ตัว ต้องไม่ขึ้นต้นด้วย YOUR_ หรือ CHANGE_ME
# ============================================================

# ===== Supabase (local stack จาก `supabase start`) =====
# รัน `supabase start` แล้ว CLI จะพิมพ์ค่า anon/service key ของ local ออกมา
# (เป็นค่าเดียวกันทุกครั้งสำหรับ local dev stack)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_LOCAL_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_LOCAL_SUPABASE_SERVICE_ROLE_KEY

# ===== PostgreSQL (Drizzle ต่อตรงผ่าน DATABASE_URL) =====
# ชี้ไป Supabase local DB (port 54322 ตาม supabase/config.toml [db])
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ===== Upstash Redis REST (rate limiting) =====
# local dev: `docker compose up` จะยก up-redis REST proxy (drop-in สำหรับ @upstash/redis)
# ที่ http://localhost:8080 ให้อัตโนมัติ — ไม่ต้องสมัคร Upstash cloud.
# host mode (pnpm dev): ใช้ localhost:8080 | container mode: docker-compose จะ override เป็น
# http://up-redis:8080 ให้เอง (ดู app environment block ใน docker-compose.yml).
# production: เปลี่ยนเป็น Upstash cloud URL+token จริง (https://console.upstash.com).
# ⚠️ token ต้อง ≥16 char (verify-env บังคับ) และตรงกับ UPREDIS_TOKEN ใน docker-compose.yml
#    (default local-dev-token-0123456789 ทั้งสองฝั่งใช้ค่าเดียวกัน — prod ต้องเปลี่ยนทั้งคู่)
UPSTASH_REDIS_REST_URL=http://localhost:8080
UPSTASH_REDIS_REST_TOKEN=local-dev-token-0123456789
#
# ⚠️ host port conflict (optional): หากเครื่องมี process อื่นจอง TCP 8080 อยู่ก่อน
#    (ตรวจ: `netstat -ano | grep :8080`) เช่น TokenAgent.exe บน Windows,
#    ให้เปลี่ยน host port ของ up-redis container แทนการ kill process ของระบบ:
#      1. สร้างไฟล์ `.env` (ถูก .gitignore แล้ว — ปลอดภัย) ใน root ของโปรเจกต์ ใส่:
#           UPREDIS_HOST_PORT=8081
#         (compose interpolation อ่านจาก `.env` หรือ shell env ตอน parse — ไม่ใช่ .env.local)
#      2. เปลี่ยนค่าใน `.env.local` ของคุณให้ตรง:
#           UPSTASH_REDIS_REST_URL=http://localhost:8081
#      3. รัน `docker compose up -d redis up-redis` ใหม่
#    default ยังเป็น 8080 สำหรับเครื่องทั่วไป — container port ยัง 8080 เสมอ.

# ===== QStash (cloud — HTTP push scheduler สำหรับ cron) =====
QSTASH_TOKEN=YOUR_QSTASH_TOKEN
QSTASH_CURRENT_SIGNING_KEY=YOUR_QSTASH_CURRENT_SIGNING_KEY
QSTASH_NEXT_SIGNING_KEY=YOUR_QSTASH_NEXT_SIGNING_KEY

# ===== CID keyed-HMAC (deduplication — สร้างเอง) =====
# local: openssl rand -hex 32   (ต้อง ≥32 char, ห้าม deterministic hash)
CID_HMAC_KEY=CHANGE_ME_TO_AT_LEAST_32_RANDOM_CHARACTERS

# ===== Vercel Cron shared secret (header Authorization: Bearer) =====
# local: openssl rand -hex 16   (ต้อง ≥16 char)
CRON_SECRET=CHANGE_ME_AT_LEAST_16_CHARS
