# ============================================================
# .env.example — อบต.หัวงัว citizen-help
# ============================================================
# 📗 วิธีใช้ไฟล์นี้ (อ่านก่อน!):
#
#   1. คัดลอกไฟล์นี้เป็น  .env.local   (สำหรับรันในเครื่อง)
#      และกรอกค่าเดียวกันใน Vercel → Settings → Environment Variables (สำหรับ production)
#
#   2. ทำตามคู่มือ DEPLOY.md ทีละขั้น แล้วมากรอกค่าในไฟล์นี้ตามหมายเลขขั้น
#      เช่น ค่าที่ได้จาก "ขั้นที่ 2" ใน DEPLOY.md → ใส่ในส่วน [2] ด้านล่าง
#
#   3. ⚠️ ลบคำว่า CHANGE_ME_... ออก แล้วแทนด้วยค่าจริงทั้งหมด
#      (ระบบจะบล็อก deploy ถ้าค่ายังขึ้นต้นด้วย CHANGE_ME_ หรือ YOUR_)
#
#   4. ห้าม commit .env.local ขึ้น GitHub (ถูก .gitignore อยู่แล้ว)
#
# ตัวแปรทั้งหมด 10 ตัว | เครื่องหมาย ✔ = บังคับกรอก, ระบบตรวจสอบอัตโนมัติตอน build
# ============================================================


# ────────────────────────────────────────────────────────────
# [ขั้น 2] 🗄️ ฐานข้อมูล Supabase (PostgreSQL)
# ────────────────────────────────────────────────────────────
# หาได้จาก: Supabase → Project Settings → Database → Connection string → URI (Transaction / port 6543)
#
#   รูปแบบ:  postgresql://postgres.<project>:<รหัสผ่าน>@<โฮสต์>:6543/postgres
#   ตัวอย่าง: postgresql://postgres.huangua:AbCd1234@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
#
# ⚠️ อย่าลืมแทน <รหัสผ่าน> ด้วยรหัสที่ตั้งตอนสร้าง project ใน Supabase
DATABASE_URL=CHANGE_ME_paste_supabase_connection_string_here


# ────────────────────────────────────────────────────────────
# [ขั้น 3] ⚡ Upstash Redis (สำหรับ rate limiting / ป้องกันสแปม)
# ────────────────────────────────────────────────────────────
# หาได้จาก: Upstash → เปิด Redis database ของคุณ → ดูส่วน REST API
#
#   UPSTASH_REDIS_REST_URL  → รูปแบบ https://xxxxx.upstash.io
#   UPSTASH_REDIS_REST_TOKEN → คลิกปุ่ม Copy (ต้อง ≥ 16 ตัวอักษร)
UPSTASH_REDIS_REST_URL=CHANGE_ME_https_colon_slash_slash_xxxxx_upstash_io
UPSTASH_REDIS_REST_TOKEN=CHANGE_ME_paste_upstash_redis_rest_token


# ────────────────────────────────────────────────────────────
# [ขั้น 4] ⏰ Upstash QStash (ตัวตั้งเวลาอัตโนมัติ / cron)
# ────────────────────────────────────────────────────────────
# หาได้จาก: Upstash → เมนู QStash → และ QStash → Settings/Keys
#
#   QSTASH_TOKEN             → คลิกปุ่ม Copy (ต้อง ≥ 16 ตัวอักษร)
#   QSTASH_CURRENT_SIGNING_KEY → ในหน้า Keys
#   QSTASH_NEXT_SIGNING_KEY     → ในหน้า Keys
QSTASH_TOKEN=CHANGE_ME_paste_qstash_token
QSTASH_CURRENT_SIGNING_KEY=CHANGE_ME_paste_qstash_current_signing_key
QSTASH_NEXT_SIGNING_KEY=CHANGE_ME_paste_qstash_next_signing_key


# ────────────────────────────────────────────────────────────
# [ขั้น 5] 🔐 รหัสลับที่สร้างเอง (generate ด้วย https://generate-secret.vercel.app/32)
# ────────────────────────────────────────────────────────────
# สร้างสตริงสุ่มยาว ๆ แต่ละตัวไม่ซ้ำกัน (ห้ามใช้ค่าเดียวกัน 3 ตัว)
#
#   AUTH_SECRET  → ≥ 32 ตัวอักษร (ใช้เซ็น session ของเจ้าหน้าที่)
#   CID_HMAC_KEY → ≥ 32 ตัวอักษร (เข้ารหัสเลขบัตรประชาชน / PDPA)
#   CRON_SECRET  → ≥ 16 ตัวอักษร (ยืนยันตัวตนงานอัตโนมัติ)
#
#   หรือถ้ามี Terminal:  openssl rand -base64 32   และ   openssl rand -hex 16
AUTH_SECRET=CHANGE_ME_paste_32plus_random_chars
CID_HMAC_KEY=CHANGE_ME_paste_32plus_random_chars
CRON_SECRET=CHANGE_ME_paste_16plus_random_chars


# ────────────────────────────────────────────────────────────
# [ขั้น 6-7] 🌐 URL ของเว็บไซต์ (Auth.js trusted URL)
# ────────────────────────────────────────────────────────────
# รันในเครื่อง:       http://localhost:3000
# Production (Vercel): https://<ชื่อโปรเจกต์>.vercel.app  (ห้ามมี / ปิดท้าย, ห้ามใช้ localhost)
#
# ⚠️ หลัง deploy ครั้งแรก ต้องกลับมาแก้ค่านี้เป็นลิงก์เว็บจริง แล้ว Redeploy
AUTH_URL=http://localhost:3000


# ============================================================
# ✅ Checklist ก่อน deploy (ระบบตรวจสอบอัตโนมัติตอน build)
# ============================================================
#  [✔] ทุกบรรทัดข้างบนถูกแทนด้วยค่าจริงหมดแล้ว (ไม่มี CHANGE_ME_ เหลืออยู่)
#  [✔] AUTH_SECRET  ยาว ≥ 32 ตัวอักษร
#  [✔] CID_HMAC_KEY ยาว ≥ 32 ตัวอักษร
#  [✔] CRON_SECRET  ยาว ≥ 16 ตัวอักษร
#  [✔] UPSTASH_REDIS_REST_TOKEN ยาว ≥ 16 ตัวอักษร
#  [✔] QSTASH_TOKEN              ยาว ≥ 16 ตัวอักษร
#  [✔] AUTH_URL (production) เป็น https:// และไม่ใช่ localhost
# ============================================================
