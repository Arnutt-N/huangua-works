# ============================================================
# .env.example — อบต.หัวงัว citizen-help (placeholder ทั้งหมด — ห้ามใส่ค่าจริง)
# คัดลอกเป็น .env.local แล้วเติมค่าจริง (.env* ถูก .gitignore ทั้งหมดยกเว้นไฟล์นี้)
# ============================================================

# ===== Auth.js v5 (staff login — Credentials provider + JWT session) =====
# AUTH_SECRET: secret สำหรับ sign JWT — generate ด้วย:
#   openssl rand -base64 32     (หรือ `pnpm exec auth secret`)
# SERVER-ONLY (ห้าม NEXT_PUBLIC_) ต้อง ≥32 char
AUTH_SECRET=CHANGE_ME_TO_AT_LEAST_32_RANDOM_CHARACTERS
# AUTH_URL: trusted URL ของแอป (ใช้คำนวณ callback URLs)
# Production: ใส่ canonical URL จริง เช่น https://huangua.go.th
AUTH_URL=http://localhost:3000

# ===== PostgreSQL (Drizzle ORM ต่อตรงผ่าน DATABASE_URL) =====
# Production: connection string ของ hosted Postgres (เช่น Supabase pooler port 6543 ถ้าใช้ Supabase Cloud)
#   ถ้าใช้ PgBouncer/Supabase pooler ใส่ ?pgbouncer=true&prepare_threshold=0 ท้าย connection string
# Local dev: `docker compose up -d postgres` ให้ค่าด้านล่าง (port 5432)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres

# ===== Upstash Redis (REST API — ไม่ใช่ RESP/TCP, fit serverless) =====
UPSTASH_REDIS_REST_URL=https://YOUR-REGION.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REDIS_REST_TOKEN

# ===== QStash (HTTP push scheduler — แยกจาก DB) =====
QSTASH_TOKEN=YOUR_QSTASH_TOKEN
QSTASH_CURRENT_SIGNING_KEY=YOUR_QSTASH_CURRENT_SIGNING_KEY
QSTASH_NEXT_SIGNING_KEY=YOUR_QSTASH_NEXT_SIGNING_KEY

# ===== CID keyed-HMAC (C2 — สร้างด้วย: openssl rand -hex 32, ≥32 char) =====
# ห้ามใช้ deterministic hash (rainbow table risk); keyed HMAC เท่านั้น
CID_HMAC_KEY=CHANGE_ME_TO_AT_LEAST_32_RANDOM_CHARACTERS

# ===== Vercel Cron shared secret (header Authorization: Bearer) =====
CRON_SECRET=CHANGE_ME_AT_LEAST_16_CHARS